# Copy this file to .env.local and fill in your keys

# Required: OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: YouTube Data API v3 key (https://console.cloud.google.com)
# When provided, app fetches REAL YouTube comments for analysis
# When missing, falls back to AI knowledge base
YOUTUBE_API_KEY=AIza...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
